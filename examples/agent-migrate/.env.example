# Your Kisenon project id (used for `keon sandbox` calls).
KISENON_PROJECT_ID=

# Connection string for the project's main branch. Used ONLY for read-only
# schema introspection (the agent's inspect_schema tool). All writes happen on
# a scoped sandbox, never here.
KISENON_URL=postgresql://app:•••••@ep_xxx.kisenon.com:5432/main?sslmode=require

# LLM provider key (one of these, matching --provider).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
